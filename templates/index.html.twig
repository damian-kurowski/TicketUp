<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticketup - Kup bilety na wydarzenia</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Global Styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background-color: #f8f9fa;
        }

        header {
            background-color: #0d6efd;
            color: white;
            padding: 20px 0;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar .logo {
            font-size: 28px;
            font-weight: bold;
        }

        nav ul {
            list-style-type: none;
            display: flex;
            gap: 20px;
        }

        nav ul li a {
            color: white;
            text-decoration: none;
            font-size: 18px;
            transition: color 0.3s;
        }

        nav ul li a:hover {
            color: #ffcc00;
        }

        .hero-section {
            margin-top: 40px;
            padding: 60px 20px;
            background-color: #007bff;
            color: white;
            text-align: center;
        }

        .hero-section h1 {
            font-size: 48px;
            font-weight: 700;
        }

        .hero-section p {
            font-size: 18px;
            margin-bottom: 20px;
        }

        .cta-btn {
            background-color: #ffcc00;
            color: #007bff;
            padding: 15px 30px;
            text-decoration: none;
            font-size: 18px;
            border-radius: 5px;
            transition: background-color 0.3s;
        }

        .cta-btn:hover {
            background-color: #ff9800;
        }

        .events-section {
            padding: 60px 20px;
            background-color: #ffffff;
            text-align: center;
        }

        .events-section h2 {
            font-size: 32px;
            margin-bottom: 40px;
            color: #333;
        }

        .event-cards {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .event-card {
            background-color: #ffffff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            width: 280px;
            transition: transform 0.3s ease;
        }

        .event-card:hover {
            transform: translateY(-10px);
        }

        .event-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .event-info {
            padding: 20px;
        }

        .event-info h3 {
            font-size: 24px;
            margin-bottom: 10px;
        }

        .event-info p {
            font-size: 16px;
            color: #555;
        }

        .btn-primary {
            background-color: #0d6efd;
            border-color: #0d6efd;
            color: white;
            border-radius: 5px;
            padding: 10px 20px;
            font-size: 16px;
            text-decoration: none;
            transition: background-color 0.3s ease;
        }

        .btn-primary:hover {
            background-color: #0056b3;
        }

        footer {
            background-color: #0d6efd;
            color: white;
            padding: 20px 0;
            text-align: center;
        }

        .navbar .user-links a {
            color: white;
            font-size: 16px;
        }

        .navbar .user-links {
            display: flex;
            gap: 10px;
        }

        .btn-cart {
            position: relative;
        }

        .cart-count {
            position: absolute;
            top: -5px;
            right: -5px;
            background-color: red;
            color: white;
            border-radius: 50%;
            padding: 5px 10px;
            font-size: 12px;
        }
        .alert {
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid transparent;
            border-radius: 4px;
        }

        .alert-danger {
            color: #721c24;
            background-color: #f8d7da;
            border-color: #f5c6cb;
        }
    </style>
</head>

<body>
<header>
    <div class="navbar container">
        <div class="logo">Ticketup</div>
        <nav>
            <ul>
                <li><a href="#">Wydarzenia</a></li>
                <li><a href="#">O nas</a></li>
                <li><a href="#">Kontakt</a></li>
            </ul>
        </nav>
        <div class="user-links">
            {% if app.user %}
                <!-- Jeśli użytkownik jest zalogowany -->
                <a href="{{ path('app_logout') }}" class="btn btn-primary">Wyloguj się</a>
            {% else %}
                <!-- Jeśli użytkownik nie jest zalogowany -->
                <a href="#" data-bs-toggle="modal" data-bs-target="#loginModal">Zaloguj się</a>
                <a href="#" data-bs-toggle="modal" data-bs-target="#registerModal">Zarejestruj się</a>
            {% endif %}
            <!-- Koszyk -->
            <a href="#" class="btn-cart">
                Koszyk
                <span class="cart-count">3</span> <!-- Example cart count -->
            </a>
        </div>
    </div>
    <div class="hero-section">
        <h1>Witaj w Ticketup!</h1>
        <p>Znajdź najnowsze wydarzenia i kup bilety online.</p>
        <a href="#events" class="cta-btn">Zobacz wydarzenia</a>
    </div>
</header>

<main>
    <section id="events" class="events-section">
        <h2>Nadchodzące wydarzenia</h2>
        <div class="event-cards">
            <div class="event-card">
                <img src="https://via.placeholder.com/300x200" alt="Wydarzenie 1">
                <div class="event-info">
                    <h3>Koncert rockowy</h3>
                    <p>Data: 25 kwietnia 2025</p>
                    <p>Godzina: 20:00</p>
                    <a href="#" class="btn btn-primary">Kup bilet</a>
                </div>
            </div>
            <div class="event-card">
                <img src="https://via.placeholder.com/300x200" alt="Wydarzenie 2">
                <div class="event-info">
                    <h3>Spektakl teatralny</h3>
                    <p>Data: 5 maja 2025</p>
                    <p>Godzina: 18:30</p>
                    <a href="#" class="btn btn-primary">Kup bilet</a>
                </div>
            </div>
        </div>
    </section>
</main>
<!-- Modal Logowania -->
<div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="loginModalLabel">Logowanie</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <form action="{{ path('app_login') }}" method="post">
                    <div class="mb-3">
                        <label for="email" class="form-label">Adres e-mail</label>
                        <input type="email" name="email" class="form-control" id="email"
                               value="{{ last_username|default('') }}" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Hasło</label>
                        <input type="password" name="password" class="form-control" id="password" required>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <button type="submit" class="btn btn-primary w-100">Zaloguj się</button>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zamknij</button>
                <a href="#" class="btn btn-link">Nie pamiętasz hasła?</a>
            </div>
        </div>
    </div>
</div>

<!-- Modal Rejestracji -->
<div class="modal fade" id="registerModal" tabindex="-1" aria-labelledby="registerModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="registerModalLabel">Rejestracja</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form action="{{ path('app_register') }}" method="post">
                    <div class="mb-3">
                        <label for="email" class="form-label">Adres e-mail</label>
                        <input type="email" name="email" class="form-control" id="email" required>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Hasło</label>
                        <input type="password" name="password" class="form-control" id="password" required>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('registration') }}">
                    <button type="submit" class="btn btn-primary w-100">Zarejestruj się</button>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zamknij</button>
                <a href="#" class="btn btn-link">Masz już konto? Zaloguj się</a>
            </div>
        </div>
    </div>
</div>

<footer>
    <div class="footer-content">
        <p>&copy; 2025 Ticketup. Wszystkie prawa zastrzeżone.</p>
    </div>
</footer>

<!-- Bootstrap JS and Popper.js -->
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.min.js"></script>
</body>

</html>
